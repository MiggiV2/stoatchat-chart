{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customDatasources": {
    "stoat-for-web": {
      "defaultRegistryUrlTemplate": "https://api.github.com/repos/stoatchat/for-web/tags?per_page=100",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": $map($filter($, function($v){$contains($v.name, \"stoat-for-web-v\")}), function($v){{\"version\": $substringAfter($v.name, \"stoat-for-web-v\"), \"digest\": $substring($v.commit.sha, 0, 7)}}), \"sourceUrl\": \"https://github.com/stoatchat/for-web\"}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^charts/stoatchat/values\\.ya?ml$"],
      "matchStrings": [
        "image:\\s*(?<depName>ghcr\\.io/stoatchat/[a-z0-9-]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^charts/stoatchat/values\\.ya?ml$"],
      "matchStrings": [
        "image:\\s*ghcr\\.io/stoatchat/for-web:(?<currentDigest>[a-f0-9]+)\\s*#\\s*v(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "custom.stoat-for-web",
      "depNameTemplate": "stoatchat/for-web",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/stoatchat/for-web"],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/stoatchat/**"],
      "groupName": "stoatchat downstream images"
    },
    {
      "matchManagers": ["helmv3"],
      "matchFileNames": ["charts/stoatchat/Chart.yaml"],
      "groupName": "stoatchat chart dependencies"
    },
    {
      "matchDatasources": ["custom.stoat-for-web"],
      "matchDepNames": ["stoatchat/for-web"],
      "groupName": "stoatchat for-web releases"
    }
  ]
}
